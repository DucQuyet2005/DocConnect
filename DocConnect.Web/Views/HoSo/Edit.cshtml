@model DocConnect.Web.Models.Entities.HoSoSucKhoe

@{
    ViewData["Title"] = "Chỉnh sửa Hồ sơ sức khỏe";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 border-top border-primary border-4 rounded-3">
                <div class="card-header bg-white border-bottom pb-0 pt-4">
                    <h4 class="fw-bold text-primary mb-3"><i class="fa-solid fa-pen-to-square me-2"></i> Chỉnh sửa Hồ sơ bệnh án</h4>
                    <p class="text-muted small">Mã Phiên khám: <span class="badge bg-secondary">#@Model.PhienTuVanId</span> | Ngày tạo: @Model.ThoiGian.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PhienTuVanId" />
                        <input type="hidden" asp-for="NguoiDungId" />
                        <input type="hidden" asp-for="ThoiGian" />
                        <input type="hidden" asp-for="TenBacSi" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="TrieuChung" class="form-label fw-bold">Triệu chứng lâm sàng</label>
                            <textarea asp-for="TrieuChung" class="form-control" rows="3" placeholder="Ghi nhận các triệu chứng của bệnh nhân..."></textarea>
                            <span asp-validation-for="TrieuChung" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="KetLuan" class="form-label fw-bold text-primary">Chẩn đoán & Đơn thuốc (Lời dặn)</label>
                            <textarea asp-for="KetLuan" class="form-control" rows="6" placeholder="Kết luận bệnh và các chỉ định y khoa..." required></textarea>
                            <span asp-validation-for="KetLuan" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-5">
                            <a asp-action="QuanLyBenhAn" class="btn btn-outline-secondary">
                                <i class="fa-solid fa-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                                <i class="fa-solid fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
