@model IEnumerable<DocConnect.Web.Models.Entities.PhienTuVan>

<h2>Danh sách bệnh nhân đang chờ tư vấn</h2>

<div class="list-group">
    @foreach (var phien in Model)
    {
        <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <h5>Bệnh nhân: @(phien.BenhNhan?.HoTen ?? "Không xác định")</h5> <small>Thời gian bắt đầu: @((phien.ThoiGianBatDauThucTe != null) ? phien.ThoiGianBatDauThucTe.Value.ToString("HH:mm dd/MM/yyyy") : "Chưa có thời gian")</small>
            </div>
            <a asp-action="CuocTroChuyen" asp-route-id="@phien.Id" class="btn btn-primary">
                Vào phòng chat
            </a>
        </div>
    }
</div>