@model IEnumerable<DocConnect.Web.Models.CoSoYTeViewModel>
@{
    ViewData["Title"] = "Cơ sở y tế liên kết - DocConect";
}

<style>
    :root {
        --brand-color: #004E9F;
        --brand-light: #eef5ff;
        --brand-hover: #003a77;
    }

    .text-brand { color: var(--brand-color) !important; }
    .bg-brand { background-color: var(--brand-color) !important; }
    
    /* Vùng tiêu đề */
    .page-title {
        font-weight: 800;
        color: var(--brand-color);
        letter-spacing: 0.5px;
    }

    /* Thanh tìm kiếm nâng cao nâng cấp */
    .search-card-advanced {
        border: 2px solid #b3d1ff !important;
        border-radius: 50px !important;
        box-shadow: 0 8px 30px rgba(0, 78, 159, 0.06) !important;
    }

    .btn-brand-search {
        background-color: var(--brand-color);
        color: white;
        border-radius: 30px;
        font-weight: 600;
        transition: background 0.2s;
    }

    .btn-brand-search:hover {
        background-color: var(--brand-hover);
        color: white;
    }

    /* Thiết kế Card Cơ sở y tế */
    .facility-card {
        transition: all 0.3s ease;
        border: 1px solid #eef2f7 !important;
    }

    .facility-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 25px rgba(0, 78, 159, 0.12) !important;
        border-color: #cbdcf7 !important;
    }

    .badge-type {
        background-color: var(--brand-light);
        color: var(--brand-color);
        font-weight: 600;
    }

    .btn-booking {
        border: 1.5px solid var(--brand-color);
        color: var(--brand-color);
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-booking:hover {
        background-color: var(--brand-color);
        color: white;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
        height: 48px;
    }
</style>

<div class="container my-5 pt-4">
    <div class="text-center mb-5">
        <h2 class="page-title text-uppercase">Cơ Sở Y Tế Liên Kết</h2>
        <p class="text-muted fs-5">Đặt lịch khám ưu tiên, không lo xếp hàng tại các hệ thống Y tế uy tín cùng <strong class="text-brand">DocConect</strong></p>
    </div>

    <div class="card search-card-advanced p-2 mx-auto mb-5" style="max-width: 900px;">
        <div class="row g-0 align-items-center">
            <div class="col-md-6 d-flex align-items-center px-4 border-end">
                <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
                <input type="text" class="form-control border-0 bg-transparent shadow-none" placeholder="Tìm triệu chứng, chuyên khoa, bệnh viện...">
            </div>
            <div class="col-md-3 d-flex align-items-center px-4">
                <i class="fa-solid fa-location-dot text-brand me-2"></i>
                <select class="form-select border-0 bg-transparent shadow-none fw-medium text-secondary">
                    <option>Hà Nội</option>
                    <option>Hồ Chí Minh</option>
                    <option>Đà Nẵng</option>
                </select>
            </div>
            <div class="col-md-3 text-end px-2">
                <button class="btn btn-brand-search w-100 py-2-5 shadow-sm"><i class="fa-solid fa-search me-1"></i> Tìm kiếm</button>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var csyt in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 rounded-4 shadow-sm overflow-hidden facility-card">
                        
                        <div class="position-relative">
                            <img src="@csyt.ImageUrl" class="w-100 object-fit-cover" style="height: 200px;" alt="@csyt.TenCSYT" 
                                 onerror="this.src='https://placehold.co/600x400/004E9F/ffffff?text=DocConect+Hospital'">
                            <span class="badge badge-type position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2 shadow-sm">
                                <i class="fa-solid fa-hospital-user me-1"></i> @csyt.LoaiCSYT
                            </span>
                        </div>
                        
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="fw-bold text-dark mb-2 text-truncate-2" title="@csyt.TenCSYT">@csyt.TenCSYT</h5>
                                <p class="text-muted small mb-4">
                                    <i class="fa-solid fa-map-location-dot text-brand me-1"></i> @csyt.DiaChiShort
                                </p>
                            </div>
                            
                            <a href="/CoSoYTe/ChiTiet/@csyt.Id" class="btn btn-booking rounded-pill w-100 py-2">
                                Đặt lịch khám tại đây <i class="fa-solid fa-chevron-right small ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted fs-5"><i class="fa-solid fa-circle-info me-2"></i> Hệ thống đang cập nhật danh sách bệnh viện...</div>
            </div>
        }
    </div>
</div>