@model IEnumerable<DocConnect.Web.Models.CoSoYTeViewModel>

@{
    ViewData["Title"] = "Cơ sở y tế liên kết - DocConect";
}

    <style>
        :root {
            --brand-color: #004E9F;
            --brand-hover: #003b79;
            --brand-light: #edf5ff;
            --text-dark: #1f2937;
            --text-gray: #6b7280;
            --border-color: #e8eef5;
            --bg-color: #f8fbff;
        }

        body {
            background: var(--bg-color);
        }

        .text-brand {
            color: var(--brand-color) !important;
        }

        /*PAGE HEADER*/

        .page-title {
            color: var(--brand-color);
            font-weight: 800;
            letter-spacing: .5px;
        }

        .page-subtitle {
            color: var(--text-gray);
            max-width: 700px;
            margin: auto;
        }
/* ================= SEARCH ================= */

.search-wrapper {
    max-width: 600px;
    margin: auto;
}

.search-card-advanced {
    background: #fff;
    border: 2px solid #d9e8fb;
    border-radius: 22px;
    box-shadow: none;
    padding: 14px 18px !important;
    transition: all .25s ease;
}

.search-card-advanced:hover,
.search-card-advanced:focus-within {
    border-color: #9fc4ff;
    box-shadow: none;
}

.search-card-advanced .form-control {
    border: none;
    background: transparent;
    box-shadow: none !important;
    font-size: 15px;
    padding: 0;
    height: 18px;
}

.search-card-advanced .form-control::placeholder {
    color: #9ca3af;
}

.search-card-advanced .form-control:focus {
    box-shadow: none;
}

.search-icon {
    color: #9ca3af;
    font-size: 18px;
    margin-right: 13px ;
}
.search-card-advanced .col-lg-3,
.search-card-advanced .col-md-4{
    display: flex;
    justify-content: flex-end;
    align-items: center;
}
/* ===== NÚT ICON TÌM KIẾM ===== */

.btn-brand-search {
    width: 50px;
    height: 34px;
    border: none;
    border-radius: 10px;
    background: var(--brand-color);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .25s ease;
    cursor: pointer;
}

.btn-brand-search i {
    font-size: 13px;
}
.btn-brand-search:hover {
    background: var(--brand-hover);
    color: #fff;
    transform: translateY(-2px);
}

.btn-brand-search:active {
    transform: scale(.96);
}

.btn-brand-search:focus {
    box-shadow: 0 0 0 .2rem rgba(0, 78, 159, .15);
    outline: none;
}
        /*IMAGE*/

        .facility-card img {
            width: 100%;
            height: 185px;
            object-fit: cover;
            transition: .45s;
        }

        .facility-card:hover img {
            transform: scale(1.06);
        }

        /*BADGE*/

        .badge-type {
            background: rgba(255,255,255,.92);
            color: var(--brand-color);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.5);
            font-size: 11px;
            font-weight: 600;
            padding: 6px 11px;
            border-radius: 30px;
        }

        /*CARD BODY*/

        .card-body {
            display: flex;
            flex-direction: column;
            padding: 16px;
        }

        .card-title {
            color: var(--text-dark);
            font-size: 18px;
            font-weight: 700;
            line-height: 1.4;
            margin-bottom: 10px;
        }

        .card-address {
            color: var(--text-gray);
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 18px;
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 50px;
        }

        /*BUTTON*/

        .btn-booking {
            border: 1.5px solid var(--brand-color);
            color: var(--brand-color);
            border-radius: 8px;
            padding: 10px 16px;
            font-size: 14px;
            font-weight: 600;
            transition: .25s;
        }

        .btn-booking:hover {
            background: var(--brand-color);
            color: white;
            transform: translateY(-2px);
        }

        /*EMPTY DATA*/

        .empty-state {
            padding: 80px 20px;
            color: var(--text-gray);
        }

        .empty-state i {
            color: #b8c2cc;
            margin-bottom: 20px;
        }

        /*RESPONSIVE*/

        @@media (max-width: 1199px) {

            .facility-card img {
                height: 175px;
            }

        }

        @@media (max-width: 991px) {

            .page-title {
                font-size: 30px;
            }

            .search-card-advanced {
                border-radius: 14px;
            }

            .facility-card img {
                height: 170px;
            }

        }

        @@media (max-width: 767px) {

            .page-title {
                font-size: 26px;
            }

            .page-subtitle {
                font-size: 15px;
            }

            .search-card-advanced {
                border-radius: 12px;
                padding: 18px !important;
            }

            .search-card-advanced .border-end {
                border-right: none !important;
                border-bottom: 1px solid #edf2f7;
                padding-bottom: 14px;
                margin-bottom: 12px;
            }

            .btn-brand-search {
                width: 100%;
            }

            .facility-card img {
                height: 165px;
            }

        }

        @@media (max-width: 576px) {

            .container {
                padding-left: 16px;
                padding-right: 16px;
            }

            .page-title {
                font-size: 23px;
            }

            .facility-card {
                border-radius: 10px;
            }

            .facility-card img {
                height: 160px;
            }

            .card-body {
                padding: 14px;
            }

            .card-title {
                font-size: 16px;
            }

            .card-address {
                font-size: 13px;
            }

        }

        @@media (max-width: 400px) {

            .facility-card img {
                height: 150px;
            }

        }
    </style>

<div class="container my-5 pt-4">

    <div class="text-center mb-5">
        <h2 class="page-title text-uppercase">
            Cơ Sở Y Tế Liên Kết
        </h2>

        <p class="text-muted fs-5">
            Đặt lịch khám ưu tiên, không lo xếp hàng tại các hệ thống Y tế uy tín cùng
            <strong class="text-brand">DocConect</strong>
        </p>
    </div>
<form asp-action="Index"
      method="get"
      class="card search-wrapper search-card-advanced p-3 mb-5">

    <div class="row align-items-center">

        <div class="col-lg-9 col-md-8 mb-3 mb-md-0">

            <div class="d-flex align-items-center">

                <i class="fa-solid fa-magnifying-glass search-icon"></i>

                <input
                    type="text"
                    name="keyword"
                    value="@ViewBag.Keyword"
                    class="form-control"
                    placeholder="Tìm theo tên cơ sở y tế, địa chỉ hoặc loại cơ sở..." />

            </div>

        </div>

        <div class="col-lg-3 col-md-4">

            <button type="submit" class="btn btn-brand-search">
                <i class="fa-solid fa-search"></i>
            </button>

        </div>

    </div>

</form>

    <div class="row g-4">

        @if (Model != null && Model.Any())
        {
            @foreach (var csyt in Model)
            {
                <!-- Desktop: 4 card / hàng -->
                <!-- Tablet: 2 card / hàng -->
                <!-- Mobile: 1 card / hàng -->

                <div class="col-12 col-sm-6 col-md-6 col-lg-3">

                    <div class="card h-100 facility-card shadow-sm">

                        <div class="position-relative">

                            <img src="@csyt.ImageUrl"
                                 class="w-100"
                                 alt="@csyt.TenCSYT"
                                 onerror="this.src='https://placehold.co/600x400/004E9F/ffffff?text=DocConect+Hospital'" />

                            <span class="badge badge-type rounded-pill px-3 py-2 position-absolute top-0 end-0 m-3 shadow-sm">
                                <i class="fa-solid fa-hospital-user me-1"></i>
                                @csyt.LoaiCSYT
                            </span>

                        </div>

                        <div class="card-body d-flex flex-column">

                            <div class="flex-grow-1">

                                <h5 class="fw-bold text-truncate-2 mb-3"
                                    title="@csyt.TenCSYT">
                                    @csyt.TenCSYT
                                </h5>

                                <p class="text-muted small mb-4">
                                    <i class="fa-solid fa-location-dot text-brand me-2"></i>
                                    @csyt.DiaChiShort
                                </p>

                            </div>

                            <a href="/CoSoYTe/ChiTiet/@csyt.Id"
                               class="btn btn-booking w-100 py-2">

                                Đặt lịch khám tại đây

                                <i class="fa-solid fa-chevron-right ms-2"></i>

                            </a>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12">

                <div class="text-center py-5">

                    <i class="fa-solid fa-circle-info fs-1 text-secondary mb-3"></i>

                    <h5 class="text-muted">
                        Hệ thống đang cập nhật danh sách bệnh viện...
                    </h5>

                </div>

            </div>
        }

    </div>

</div>