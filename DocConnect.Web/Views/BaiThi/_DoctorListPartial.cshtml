@model IEnumerable<DocConnect.Web.Models.Entities.HoSoBacSi>

@if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var bacSi in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@bacSi.NguoiDung?.HoTen</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@bacSi.ChuyenKhoa?.TenChuyenKhoa</h6>
                        
                        <p class="card-text small mt-3 mb-1">
                            <strong>Mã TX:</strong> @bacSi.AccessCode
                        </p>
                        <p class="card-text small text-truncate">
                            <strong>KN:</strong> @(string.IsNullOrEmpty(bacSi.KinhNghiem) ? "Chua cap nhat" : bacSi.KinhNghiem)
                        </p>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <a href="#" class="btn btn-sm btn-outline-info w-100">Chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
       Khong tim thay bac si nao thuoc chuyen khoa nay
    </div>
}
