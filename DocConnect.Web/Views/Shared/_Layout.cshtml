<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DocConect - Nền tảng chăm sóc sức khỏe 24/7</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root { --main-color: #004E9F; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; }
        .bg-main { background-color: var(--main-color) !important; }
        .text-main { color: var(--main-color) !important; }
        .btn-main { background-color: var(--main-color); color: white; border: none; }
        .btn-main:hover { background-color: #003a75; color: white; }
        
        /* Top Bar */
        .top-bar { background: #f8f9fa; font-size: 14px; padding: 5px 0; border-bottom: 1px solid #ddd; }
        
        /* Navbar */
        .navbar-brand { font-weight: bold; font-size: 24px; color: var(--main-color) !important; }
        .nav-link { font-weight: 500; color: #444; margin-right: 15px; }
        .nav-link:hover { color: var(--main-color); }

        /* Footer */
        footer { background-color: var(--main-color); color: white; padding: 40px 0 20px; }
        footer a { color: #ddd; text-decoration: none; font-size: 14px; }
        footer a:hover { color: white; }
    </style>
</head>
<body>
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div><i class="fa fa-phone me-1"></i> Hotline đặt khám: <strong>1900 xxxx</strong></div>
            <div class="d-flex gap-3">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-dark">Đăng nhập</a>
                    <a asp-controller="Account" asp-action="Register" class="text-decoration-none text-dark">Đăng ký</a>
                }
                else
                {
                    <span>Chào, @User.Identity.Name</span>
                    <a asp-controller="Account" asp-action="Logout" class="text-decoration-none text-danger">Thoát</a>
                }
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-circle-plus"></i> DocConect
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                    <a class="nav-link" asp-controller="BacSi" asp-action="Index">
                    <i class="fa-solid fa-user-doctor me-1"></i> Bác sĩ
                    </a>
                    </li>
                    <li class="nav-item">
                    <a class="nav-link" asp-controller="CoSoYTe" asp-action="Index">Cơ sở y tế</a>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="#">Chuyên khoa</a></li>
                    <li class="nav-item">
                    <a class="nav-link" href="/HoiDap/HoiDap">Hỏi đáp bác sĩ</a>
                    </li>
                    <li class="nav-item"><a class="nav-link btn btn-outline-primary text-main ms-2" href="#">Hồ sơ sức khỏe</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5>DocConect - Nền tảng y tế</h5>
                    <p class="small mt-3">Tầng 10, Tòa nhà Y tế, Hà Nội.<br>Email: support@docconect.vn</p>
                    <div class="d-flex gap-3 mt-3">
                        <i class="fab fa-facebook fa-xl"></i>
                        <i class="fab fa-youtube fa-xl"></i>
                        <i class="fab fa-zalo fa-xl"></i>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h6>Đặt lịch</h6>
                    <ul class="list-unstyled">
                        <li><a href="#">Bác sĩ</a></li>
                        <li><a href="#">Cơ sở y tế</a></li>
                        <li><a href="#">Chuyên khoa</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6>Chính sách</h6>
                    <ul class="list-unstyled">
                        <li><a href="#">Điều khoản sử dụng</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Quy chế hoạt động</a></li>
                    </ul>
                </div>
                <div class="col-md-3 text-center">
                    <h6>Tải ứng dụng ngay</h6>
                    <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" width="140" class="mb-2">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" width="140">
                </div>
            </div>
            <hr>
            <p class="text-center small mb-0">© 2024 DocConect. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>