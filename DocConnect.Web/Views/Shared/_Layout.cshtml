<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DocConect - Nền tảng chăm sóc sức khỏe 24/7</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root { --main-color: #004E9F; }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            color: #333; 
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }
        main {
            flex: 1 0 auto;
        }
        .bg-main { background-color: var(--main-color) !important; }
        .text-main { color: var(--main-color) !important; }
        .btn-main { background-color: var(--main-color); color: white; border: none; }
        .btn-main:hover { background-color: #003a75; color: white; }
        
        /* Top Bar */
        .top-bar { background: #f8f9fa; font-size: 14px; padding: 5px 0; border-bottom: 1px solid #ddd; }
        
        /* Navbar */
        .navbar-brand { font-weight: bold; font-size: 24px; color: var(--main-color) !important; }
        .nav-link { font-weight: 500; color: #444; margin-right: 15px; }
        .nav-link:hover { color: var(--main-color); }

        /* Footer */
        footer { background-color: var(--main-color); color: white; padding: 40px 0 20px; flex-shrink: 0; }
        footer a { color: #ddd; text-decoration: none; font-size: 14px; }
        footer a:hover { color: white; }

        #notification-area {
            position: fixed;
            right: 20px;
            bottom: 20px;
            z-index: 1085;
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: min(360px, calc(100vw - 40px));
        }

        .notification-card {
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid rgba(0, 78, 159, 0.16);
            border-radius: 18px;
            box-shadow: 0 18px 44px rgba(15, 23, 42, 0.16);
            overflow: hidden;
        }

        .notification-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 14px;
            background: linear-gradient(135deg, #eef5ff, #ffffff);
            border-bottom: 1px solid rgba(0, 78, 159, 0.08);
        }

        .notification-card-title {
            font-weight: 700;
            color: var(--main-color);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .notification-card-body {
            padding: 14px;
            color: #334155;
        }

        .notification-card-body .btn {
            border-radius: 999px;
            padding-left: 14px;
            padding-right: 14px;
        }

        .notification-close {
            border: none;
            background: transparent;
            color: #64748b;
            font-size: 18px;
            line-height: 1;
        }
        #notificationBody {
            max-height: 400px;
            overflow-y: auto;
            background: white;
        }
        .text-truncate {
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        #chatNotificationList {
            transition: all 0.3s ease;
            transform-origin: bottom right;
        }
        /* Active menu */
.nav-link {
    font-weight: 500;
    color: #444 !important;
    margin-right: 15px;
    transition: color .2s ease;
}

.nav-link:hover {
    color: var(--main-color) !important;
}

/* Menu đang được chọn */
.nav-link.active {
    color: var(--main-color) !important;
    font-weight: 700;
}

    </style>
</head>

<div id="chat-notification-tray" style="position:fixed; bottom:20px; right:20px; z-index:9999;">
    <button id="btnToggleChat" class="btn btn-primary rounded-circle shadow-lg" style="width:60px; height:60px; position:relative;">
        <i class="fa-solid fa-comment-dots"></i>
        <span id="badgeCount" class="badge bg-danger position-absolute top-0 start-100 translate-middle" style="display:none;">0</span>
    </button>
    
    <div id="chatNotificationList" class="card shadow-lg" style="display:none; width:300px; position:absolute; bottom:80px; right:0; border-radius:10px; background: white;">
        <div class="card-header bg-primary text-white">Tin nhắn chờ</div>
        <div class="card-body p-0" id="notificationBody" style="max-height:300px; overflow-y:auto;">
            </div>
    </div>
</div>

<div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
</div>

<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="notification-area" aria-live="polite"></div>
    }

    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div><i class="fa fa-phone me-1"></i> Hotline đặt khám: <strong>1900 xxxx</strong></div>
            <div class="d-flex gap-3">
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-dark">Đăng nhập</a>
                    <a asp-controller="Account" asp-action="Register" class="text-decoration-none text-dark">Đăng ký</a>
                }
                else
                {
                    <span>Chào, @(User.Identity?.Name ?? "bạn")</span>
                    <a asp-controller="Account" asp-action="Logout" class="text-decoration-none text-danger">Thoát</a>
                }
            </div>
        </div>
    </div>
    @{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-circle-plus"></i> DocConect
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                    <a class="nav-link @(currentController=="BacSi" ? "active" : "")"
                    asp-controller="BacSi" asp-action="Index"> <i class="fa-solid fa-user-doctor me-1"></i> Bác sĩ
                    </a>
                    </li>
                    <li class="nav-item">
                    <a class="nav-link @(currentController=="CoSoYTe" ? "active" : "")"
                    asp-controller="CoSoYTe" asp-action="Index"> Cơ sở y tế</a>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="#">Chuyên khoa</a></li>
                    <li class="nav-item">
                    <a class="nav-link @(currentController=="HoiDap" ? "active" : "")" asp-controller="HoiDap" asp-action="HoiDap"> Hỏi đáp bác sĩ
                    </a>
                    </li>
                    @if (User.IsInRole("Doctor")) 
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController=="TinNhan" ? "active" : "") text-primary fw-bold" asp-controller="TinNhan" asp-action="DanhSachPhien"> Tư vấn khách hàng
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                            <a class="nav-link btn btn-outline-primary text-main ms-2" asp-controller="HoSo" asp-action="Index">Hồ sơ sức khỏe</a>
                        </li>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5>DocConect - Nền tảng y tế</h5>
                    <p class="small mt-3">Tầng 10, Tòa nhà Y tế, Hà Nội.<br>Email: support@docconect.vn</p>
                    <div class="d-flex gap-3 mt-3">
                        <i class="fab fa-facebook fa-xl"></i>
                        <i class="fab fa-youtube fa-xl"></i>
                        <i class="fab fa-zalo fa-xl"></i>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h6>Đặt lịch</h6>
                    <ul class="list-unstyled">
                        <li><a href="#">Bác sĩ</a></li>
                        <li><a href="#">Cơ sở y tế</a></li>
                        <li><a href="#">Chuyên khoa</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6>Chính sách</h6>
                    <ul class="list-unstyled">
                        <li><a href="#">Điều khoản sử dụng</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Quy chế hoạt động</a></li>
                    </ul>
                </div>
                <div class="col-md-3 text-center">
                    <h6>Tải ứng dụng ngay</h6>
                    <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" width="140" class="mb-2">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" width="140">
                </div>
            </div>
            <hr>
            <p class="text-center small mb-0">© 2026 DocConnect. All rights reserved.</p>
        </div>
    </footer>


   @if (User.Identity?.IsAuthenticated == true)
    {
        <div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;"></div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                // Khởi tạo kết nối SignalR
                const notificationConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/chatHub")
                    .withAutomaticReconnect()
                    .build();

                const btnToggle = document.getElementById('btnToggleChat');
                const notificationList = document.getElementById('chatNotificationList');
                const badge = document.getElementById('badgeCount');
                const notificationBody = document.getElementById('notificationBody');

                // --- HÀM RENDER LẠI DANH SÁCH TỪ LOCALSTORAGE ---
                function renderNotificationList() {
                    let tinNhanCho = JSON.parse(localStorage.getItem('tinNhanCho') || '[]');
                    if (notificationBody) {
                        notificationBody.innerHTML = ''; 
                        tinNhanCho.forEach(item => {
                            notificationBody.insertAdjacentHTML('beforeend', `
                                <a href="/TinNhan/CuocTroChuyen/${item.phienId}" class="list-group-item list-group-item-action p-2 border-bottom">
                                    <div class="small fw-bold">Tin nhắn mới</div>
                                    <div class="text-truncate" style="font-size:0.85rem;">${item.message}</div>
                                </a>`);
                        });
                    }
                    if (badge) {
                        badge.style.display = tinNhanCho.length > 0 ? 'inline-block' : 'none';
                        badge.innerText = tinNhanCho.length;
                    }
                }

                // Gọi render ngay khi load trang
                renderNotificationList();

                // Xử lý đóng/mở bảng tin nhắn chờ
                if (btnToggle) {
                    btnToggle.addEventListener('click', function () {
                        notificationList.style.display = (notificationList.style.display === 'none' || notificationList.style.display === '') ? 'block' : 'none';
                    });
                }

                // 2. Logic lắng nghe sự kiện
                notificationConnection.on("ReceiveNotification", function (phienId, message) {
                    // A. Lưu vào LocalStorage
                    let tinNhanCho = JSON.parse(localStorage.getItem('tinNhanCho') || '[]');
                    tinNhanCho.unshift({ phienId: phienId, message: message });
                    localStorage.setItem('tinNhanCho', JSON.stringify(tinNhanCho));
                    renderNotificationList();

                    // B. Cập nhật giao diện nếu đang ở trang DanhSachPhien
                    const phienElement = document.querySelector(`[data-phien-id="${phienId}"]`);
                    if (phienElement) {
                        phienElement.classList.add('border-primary');
                        const badgeMoi = phienElement.querySelector('.badge-moi');
                        if (badgeMoi) badgeMoi.style.display = 'inline';
                        const text = phienElement.querySelector('.tin-nhan-cuoi');
                        if (text) text.innerText = message;
                    }

                    // C. Hiện Toast thông báo (không dùng localStorage cho Toast vì nó tự xóa)
                    const toastHtml = `<div class="toast show align-items-center text-white bg-primary border-0 mb-2"><div class="d-flex"><div class="toast-body"><strong>Tin nhắn mới:</strong> ${message}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>`;
                    const container = document.getElementById('toastContainer');
                    if (container) {
                        container.insertAdjacentHTML('beforeend', toastHtml);
                        setTimeout(() => { const toast = container.querySelector('.toast'); if (toast) toast.remove(); }, 5000);
                    }
                });

                notificationConnection.start().catch(err => console.error(err));
            });
        </script>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>