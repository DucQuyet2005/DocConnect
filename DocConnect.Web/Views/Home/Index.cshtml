<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("mainSearchInput");
        const suggestionsBox = document.getElementById("suggestionsBox");
        const locationBtn = document.getElementById("locationBtn");
        const locationMenu = document.getElementById("locationMenu");
        const selectedLocation = document.getElementById("selectedLocation");

        // 1. Logic ẩn hiện bảng Gợi ý chuyên khoa
        searchInput.addEventListener("focus", function () {
            suggestionsBox.style.display = "block";
            locationMenu.style.display = "none"; 
        });

        // 2. Logic ẩn hiện danh sách Chọn địa điểm
        locationBtn.addEventListener("click", function (e) {
            e.stopPropagation();
            const isMenuOpen = locationMenu.style.display === "block";
            locationMenu.style.display = isMenuOpen ? "none" : "block";
            suggestionsBox.style.display = "none"; 
        });

        // 3. Logic khi lựa chọn một Tỉnh/Thành phố cụ thể
        const locationItems = locationMenu.getElementsByTagName("li");
        for (let item of locationItems) {
            item.addEventListener("click", function (e) {
                selectedLocation.innerText = this.innerText;
                locationMenu.style.display = "none";
                e.stopPropagation();
            });
        }

        // 4. Logic nhấp vào thẻ triệu chứng/chuyên khoa đưa chữ lên thanh tìm kiếm
        document.querySelectorAll(".symptom-tag, .specialty-item").forEach(item => {
            item.addEventListener("click", function (e) {
                e.preventDefault();
                const text = this.querySelector(".specialty-name") ? this.querySelector(".specialty-name").innerText : this.innerText;
                searchInput.value = text;
                suggestionsBox.style.display = "none";
            });
        });

        // 5. Click ra ngoài vùng tìm kiếm thì tự động đóng tất cả bảng dropdown
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".search-wrapper")) {
                suggestionsBox.style.display = "none";
                locationMenu.style.display = "none";
            }
        });
    });
</script>