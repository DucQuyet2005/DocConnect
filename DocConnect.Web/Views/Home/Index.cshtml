@model IEnumerable<DocConnect.Web.Models.ViewModels.BacSiViewModel>

@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    :root {
        --brand-color: #004E9F;
    }

    /* Các class màu chủ đạo bổ sung */
    .btn-main {
        background-color: var(--brand-color);
        color: white;
    }
    .btn-main:hover {
        background-color: #003a77;
        color: white;
    }
    .text-main {
        color: var(--brand-color);
    }
    .bg-main {
        background-color: var(--brand-color);
        color: white;
    }

    .hero-section {
        background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
        padding: 60px 0;
    }
    .service-card {
        border: none;
        border-radius: 15px;
        transition: 0.3s;
        text-align: center;
        padding: 25px;
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        height: 100%;
    }
    .service-card:hover { transform: translateY(-10px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
    .service-card i { font-size: 40px; color: var(--brand-color); margin-bottom: 15px; }
    
    .search-box {
        background: white;
        border-radius: 50px;
        padding: 10px 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        max-width: 800px;
        margin: -35px auto 0;
    }
    .search-box input { border: none; outline: none; flex: 1; padding: 10px; }
    .search-box .btn-search { background: var(--brand-color); color: white; border-radius: 30px; padding: 8px 25px; }

    .section-title { font-weight: bold; color: var(--brand-color); margin-bottom: 30px; }

    /* Khối bọc thanh tìm kiếm chính */
    .search-wrapper {
        max-width: 950px;
        margin: -40px auto 0;
        position: relative;
        z-index: 999;
    }

    .main-search-bar {
        background: #ffffff;
        border: 2px solid #b3d1ff;
        border-radius: 16px;
        padding: 6px 10px;
        box-shadow: 0 8px 30px rgba(0, 78, 159, 0.08);
        display: flex;
        align-items: center;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

    .main-search-bar:focus-within {
        border-color: var(--brand-color);
        box-shadow: 0 8px 30px rgba(0, 78, 159, 0.15);
    }

    /* Ô nhập nội dung bên trái */
    .search-input-group {
        flex: 2;
        display: flex;
        align-items: center;
        padding-left: 15px;
    }

    .search-input-group input {
        border: none;
        outline: none;
        width: 100%;
        padding: 12px 10px;
        font-size: 15px;
        color: #333;
    }

    /* Đường vách ngăn giữa */
    .search-divider {
        width: 1px;
        height: 30px;
        background-color: #e0e0e0;
        margin: 0 10px;
    }

    /* Bộ chọn địa điểm ở giữa */
    .search-location-group {
        position: relative;
        flex: 1;
    }

    .location-trigger {
        background: transparent;
        border: none;
        width: 100%;
        padding: 12px 15px;
        text-align: left;
        font-size: 15px;
        color: #777;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

    .location-dropdown-menu {
        position: absolute;
        top: 110%;
        left: 0;
        width: 100%;
        background: white;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        border: 1px solid #eee;
        display: none;
        max-height: 250px;
        overflow-y: auto;
        padding: 5px 0;
        z-index: 1000;
    }

    .location-dropdown-menu li {
        padding: 10px 15px;
        list-style: none;
        cursor: pointer;
        font-size: 14px;
        transition: background 0.2s;
    }

    .location-dropdown-menu li:hover {
        background-color: #f0f6ff;
        color: var(--brand-color);
    }

    /* Nút tìm kiếm bên phải */
    .btn-search-submit {
        background-color: var(--brand-color);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s;
    }

    .btn-search-submit:hover {
        background-color: #003a77;
    }

    /* Bảng gợi ý chuyên khoa thông minh */
    .search-suggestions-box {
        position: absolute;
        top: 105%;
        left: 0;
        width: 100%;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.12);
        border: 1px solid #eef2f7;
        padding: 25px;
        display: none;
        z-index: 1000;
    }

    .suggestion-title {
        font-size: 15px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 20px;
    }

    /* Grid danh sách chuyên khoa */
    .specialty-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin-bottom: 25px;
    }
    @@media (min-width: 576px) { .specialty-grid { grid-template-columns: repeat(4, 1fr); } }
    @@media (min-width: 992px) { .specialty-grid { grid-template-columns: repeat(8, 1fr); } }

    .specialty-item {
        text-align: center;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .specialty-item:hover {
        transform: translateY(-3px);
    }

    .specialty-icon-wrapper {
        width: 50px;
        height: 50px;
        border-radius: 14px;
        background-color: #f4f8fc;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
        color: var(--brand-color);
        font-size: 20px;
        transition: background 0.2s;
    }

    .specialty-item:hover .specialty-icon-wrapper {
        background-color: #e2eeff;
    }

    .specialty-name {
        font-size: 12px;
        color: #4a5568;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Tag từ khóa triệu chứng */
    .symptom-tags-flex {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .symptom-tag {
        background: #f1f5f9;
        color: #4a5568;
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 13px;
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .symptom-tag:hover {
        background: #e2eeff;
        color: var(--brand-color);
        border-color: #cbdcf7;
    }
    .card img.card-img-top{
    border-radius:12px 12px 0 0;
}

.card{
    border-radius:12px;
}

.card:hover{
    transform:translateY(-4px);
    transition:.3s;
}

.section-title{
    color:#0aa596;
    font-weight:700;
}

body{
    background:#eef8f8;
}
/*  THỐNG KÊ  */

